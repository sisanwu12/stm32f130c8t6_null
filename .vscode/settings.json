{
    "clangd.path": "nix",
    "clangd.arguments": [
        "develop",
        "--quiet",
        ".",
        "--command",
        "clangd",
        "--background-index",
        "--header-insertion=never",
        "--query-driver=arm-none-eabi-*,/nix/store/*/bin/arm-none-eabi-*"
    ],
    "files.associations": {
        "*.h": "c",
        "*.c": "c"
    },
    "editor.formatOnSave": true,
    "[c]": {
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
    },
    "[cpp]": {
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
    },
    "C_Cpp.intelliSenseEngine": "disabled", // 关闭微软插件
    "terminal.integrated.profiles.linux": {
        "bash (nix develop)": {
            "path": "bash",
            "args": [
                "-lc",
                "exec nix develop"
            ],
            "overrideName": true
        }
    },
    "terminal.integrated.defaultProfile.linux": "bash (nix develop)",
    "terminal.integrated.automationProfile.linux": {
        "path": "bash",
        "args": [
            "-lc"
        ]
    }
}
