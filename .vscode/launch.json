{
  "configurations": [
    {
      "name": "Debug with OpenOCD",
      "type": "cortex-debug",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/build/null_proj.elf",
      "preLaunchTask": "Debug Build",
      "device": "STM32F103C8T6",
      "servertype": "openocd",
      "serverpath": "/nix/store/v186ra1zi00r4y216pnz6cmm5cgvpyk4-openocd-0.12.0/bin/openocd",
      "gdbPath": "/nix/store/jg6gb2j5gpycgmvhkcwq20ghfw6vdcyl-gcc-arm-embedded-15.2.rel1/bin/arm-none-eabi-gdb",
      "configFiles": [
        "interface/cmsis-dap.cfg",
        "target/stm32f1x.cfg"
      ],
      "searchDir": [],
      "interface": "swd",
      "runToEntryPoint": "main",
      "svdFile": "${workspaceFolder}/project/STM32F103xx.svd",
      "showDevDebugOutput": "none"
    }
  ]
}
