# .clangd
If:
  PathMatch: .*\.h
CompileFlags:
  Add:
    - -x
    - c-header
---
If:
  PathMatch: .*\.c
CompileFlags:
  Add:
    - -x
    - c
---
CompileFlags:
  Add:
    - -std=c11
    - --target=arm-none-eabi
    - -mcpu=cortex-m3
    - -mthumb
    - -ffreestanding
    - --gcc-toolchain=/opt/arm-gnu-toolchain-15.2.rell
